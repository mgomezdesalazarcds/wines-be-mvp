generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A liquor store / retailer using the app. Each company curates its own
/// listing (price, stock, voice/copy) on top of the shared wine catalog.
model Company {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?  @map("logo_url")
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  wines CompanyWine[]

  @@map("companies")
}

/// The generic wine catalog — one row per real-world wine, shared across every
/// company. Not a specific bottle: no vintage here, since the same SKU can be
/// restocked under a different vintage.
///
/// `extraData` is the AI-generated enrichment (tasting_notes, taste_profile,
/// pairs_well_with, variety, region, country, body/acidity/tannin/sweetness,
/// dryness_label, why_we_love_it, from_the_team, provenance) — the default
/// copy every company starts from.
///
/// `isWine`/`section`/`sectionSource` are objective classification facts
/// about the item (is it actually a wine bottle, what country it's from) —
/// same for every company, unlike `staffPick` which is a per-store curation
/// choice and lives on `CompanyWine`. `section` is a plain indexed column
/// (not folded into `extraData`) because search scopes/filters on it
/// directly in raw SQL for performance.
///
/// `size` lives here, not on `CompanyWine`: a 750ml and a 1.5L magnum of the
/// same label are different products (different price, different generic
/// wine), not the same wine presented differently per store. Import-time
/// dedup (matching a new CSV row to an existing Wine) keys on `itemName` +
/// `size` together for this reason.
model Wine {
  id            String   @id @default(uuid())
  itemName      String   @map("item_name")
  size          String?
  isWine        Boolean  @default(false) @map("is_wine")
  section       String?
  sectionSource String   @default("heuristic") @map("section_source")
  extraData     Json?    @map("extra_data")
  createdAt     DateTime @default(now()) @map("created_at")

  companies CompanyWine[]

  @@index([itemName], map: "idx_wines_name")
  @@index([section], map: "idx_wines_section")
  @@map("wines")
}

/// A company's listing of a wine — everything that varies per store.
///
/// `extraData` is null until the company edits their copy; when set, it's
/// the same shape as `Wine.extraData` and takes priority — the API resolves
/// a listing's enrichment as `companyWine.extraData ?? wine.extraData`, so
/// a company only needs to override the fields it actually wants to change.
model CompanyWine {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  wineId       String   @map("wine_id")
  lookupCode   String   @map("lookup_code")
  price        Float
  stockCount   Int?     @map("stock_count")
  availability String?
  staffPick    Boolean  @default(false) @map("staff_pick")
  imageUrl     String?  @map("image_url")
  extraData    Json?    @map("extra_data")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  wine    Wine    @relation(fields: [wineId], references: [id])

  @@unique([companyId, lookupCode])
  @@index([companyId, staffPick], map: "idx_company_wines_staff")
  @@map("company_wines")
}

model ScanLog {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  status            String
  extractedText     String?  @map("extracted_text")
  matchedLookupCode String?  @map("matched_lookup_code")
  confidence        Float?
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("scan_logs")
}

/// Generic failure log for things that don't have their own table — a scan
/// that errored out before producing a ScanLog, a search with no results.
model FailureLog {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  source    String
  message   String
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, source])
  @@map("failure_logs")
}

/// A CSV inventory file a company uploaded via the admin import screen — the
/// raw file itself (so it can be downloaded again later), plus a summary of
/// what importCsvForCompany() did with it.
model CsvImport {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  filename     String
  content      String
  totalRows    Int      @map("total_rows")
  createdCount Int      @map("created_count")
  reusedCount  Int      @map("reused_count")
  updatedCount Int      @map("updated_count")
  skippedCount Int      @map("skipped_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("csv_imports")
}
