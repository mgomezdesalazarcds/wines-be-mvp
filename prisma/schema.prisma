generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A liquor store / retailer using the app. Each company curates its own
/// listing (price, stock, voice/copy) on top of the shared wine catalog.
model Company {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?  @map("logo_url")
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  wines CompanyWine[]

  @@map("companies")
}

/// The generic wine catalog — one row per real-world wine, shared across every
/// company. Not a specific bottle: no vintage here, since the same SKU can be
/// restocked under a different vintage.
///
/// `extraData` is the AI-generated enrichment (tasting_notes, taste_profile,
/// pairs_well_with, variety, region, country, body/acidity/tannin/sweetness,
/// dryness_label, why_we_love_it, from_the_team, provenance) — the default
/// copy every company starts from.
model Wine {
  id        String   @id @default(uuid())
  itemName  String   @map("item_name")
  extraData Json?    @map("extra_data")
  createdAt DateTime @default(now()) @map("created_at")

  companies CompanyWine[]

  @@index([itemName], map: "idx_wines_name")
  @@map("wines")
}

/// A company's listing of a wine — everything that varies per store.
///
/// `extraData` is null until the company edits their copy; when set, it's
/// the same shape as `Wine.extraData` and takes priority — the API resolves
/// a listing's enrichment as `companyWine.extraData ?? wine.extraData`, so
/// a company only needs to override the fields it actually wants to change.
model CompanyWine {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  wineId       String   @map("wine_id")
  lookupCode   String   @map("lookup_code")
  price        Float
  size         String?
  stockCount   Int?     @map("stock_count")
  availability String?
  isWine       Boolean  @default(false) @map("is_wine")
  staffPick    Boolean  @default(false) @map("staff_pick")
  imageUrl     String?  @map("image_url")
  extraData    Json?    @map("extra_data")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  wine    Wine    @relation(fields: [wineId], references: [id])

  @@unique([companyId, lookupCode])
  @@index([companyId, staffPick], map: "idx_company_wines_staff")
  @@map("company_wines")
}
